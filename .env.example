# ─────────────────────────────────────────────────────────────
#  SceneSolver — Environment Variables
#  Copy this file to .env and fill in your values.
#  ⚠  Never commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────

# Flask secret key — used to sign session cookies.
# Generate a strong random value with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_secret_key

# MongoDB Atlas connection string.
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/scene_solver_db?retryWrites=true&w=majority

# ─── Optional ────────────────────────────────────────────────

# Set to "production" when deploying; controls Flask debug mode behaviour.
# FLASK_ENV=development

# Override the default port (used by some hosting platforms).
# PORT=5000
